# ===============================================
# TELEGRAM CLONE - Environment Configuration
# ===============================================
# MUHIM: Production uchun barcha parollarni o'zgartiring!

# Database Configuration
POSTGRES_USER=tguser
POSTGRES_PASSWORD=CHANGE-THIS-STRONG-DB-PASSWORD-MIN-16-CHARS
DB_HOST=postgres
DB_PORT=5432
DB_NAME=telegram_db
DB_SSLMODE=disable

# JWT Configuration (Production uchun ALBATTA o'zgartiring!)
JWT_SECRET=CHANGE-THIS-VERY-STRONG-SECRET-KEY-MIN-32-CHARACTERS-RANDOM
JWT_ISSUER=telegram-clone-backend
JWT_TTL_HOURS=72

# Server Configuration
APP_ENV=development
SERVER_PORT=8084

# CORS Configuration (production uchun domenlaringizni kiriting)
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:8082,https://localhost:8082,http://localhost:3000

# Rate Limiting
AUTH_RATE_LIMIT_MAX=5

# Upload Configuration
UPLOAD_MAX_MB=40
UPLOAD_DIR=/app/uploads

# ===============================================
# PRODUCTION UCHUN XAVFSIZLIK MASLAHATLARI:
# ===============================================
# 1. JWT_SECRET kamida 32 ta tasodifiy belgi bo'lishi kerak
# 2. POSTGRES_PASSWORD kamida 16 ta belgidan iborat murakkab parol
# 3. APP_ENV=production qilib o'rnating
# 4. DB_SSLMODE=require yoki verify-full qilib o'rnating (SSL sertifikat kerak)
# 5. CORS_ALLOWED_ORIGINS faqat ishonchli domenlar
# 6. Barcha portlarni firewall orqali himoyalang
# ===============================================
