{
  "expo": {
    "name": "S Chat",
    "slug": "s-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#071631"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.schat.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for video calls and taking photos",
        "NSMicrophoneUsageDescription": "Used for voice messages and calls",
        "NSPhotoLibraryUsageDescription": "Used for sharing photos and videos",
        "NSLocationWhenInUseUsageDescription": "Used for sharing location in messages"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#071631"
      },
      "package": "com.schat.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-av",
      "expo-document-picker",
      "expo-image-picker",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "ef6d0f1d-7d3c-4844-9dfe-1150caaaae48"
      }
    }
  }
}
