{
  "expo": {
    "name": "LUXCHAT",
    "slug": "luxchat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#071631"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.luxchat.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for video calls and taking photos",
        "NSMicrophoneUsageDescription": "Used for voice messages and calls",
        "NSPhotoLibraryUsageDescription": "Used for sharing photos and videos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#071631"
      },
      "package": "com.luxchat.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-av",
      "expo-document-picker",
      "expo-image-picker",
      "expo-asset",
      "expo-font"
    ]
  }
}
