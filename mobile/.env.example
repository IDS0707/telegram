# ===============================================
# S Chat MOBILE - Environment Configuration
# ===============================================
# Expo SDK 49+ inlines EXPO_PUBLIC_* vars at build time.
# Copy this file to mobile/.env and fill in your values.

# Backend API server (LAN IP for iOS, leave default for Android USB)
EXPO_PUBLIC_API_HOST=192.168.1.10
EXPO_PUBLIC_API_PORT=8084
EXPO_PUBLIC_API_SCHEME=http

# Web/desktop dev backend (used when Platform.OS === 'web')
EXPO_PUBLIC_WEB_API_URL=http://localhost:8084

# Android USB debug backend (adb reverse)
EXPO_PUBLIC_ANDROID_USB_API_URL=http://127.0.0.1:8084

# TURN server for WebRTC calls (must match backend turn/turnserver.conf)
EXPO_PUBLIC_TURN_HOST=YOUR_TURN_HOST
EXPO_PUBLIC_TURN_PORT=3478
EXPO_PUBLIC_TURN_USER=turnuser
EXPO_PUBLIC_TURN_PASS=CHANGE_ME
